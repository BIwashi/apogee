# Go
/bin/
/dist/
*.test
*.out
coverage.*

# Local sandbox scratch (created by codex read-only harness + manual runs).
# These hold go-build caches, module caches, and temporary binaries — none
# of them belong in the tree.
/.cache/
/.tmp/

# Embedded webassets: keep the checked-in placeholder index.html, ignore any
# built artefacts that `make web-build` drops here.
/internal/webassets/dist/*
!/internal/webassets/dist/index.html

# Node / Next.js
node_modules/
.next/
out/
.turbo/
.pnpm-store/
*.tsbuildinfo

# apogee runtime data
/data/
*.duckdb
*.duckdb.wal
*.duckdb.tmp

# Local env
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json.example
*.swp

# Logs
*.log

# Claude Code local state
.claude/data/
.claude/logs/

# Contributor-local Claude Code orientation. CLAUDE.md was previously
# tracked but carries dev-only meta (PR conventions, dev commands,
# internal architecture notes) that duplicates CONTRIBUTING.md /
# README.md for OSS visitors. The file is now local-only so anyone
# running Claude Code against this repo can keep their own CLAUDE.md
# without re-committing it by accident.
CLAUDE.md

# External reference PDFs (design guides, spec exports) — keep
# locally for contributor reference without risking a third-party
# copyright upload to the OSS repo.
*.pdf
