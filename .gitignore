# Go
/bin/
/dist/
*.test
*.out
coverage.*

# Local sandbox scratch (created by codex read-only harness + manual runs).
# These hold go-build caches, module caches, and temporary binaries — none
# of them belong in the tree.
/.cache/
/.tmp/

# Embedded webassets: keep the checked-in placeholder index.html, ignore any
# built artefacts that `make web-build` drops here.
/internal/webassets/dist/*
!/internal/webassets/dist/index.html

# Node / Next.js
node_modules/
.next/
out/
.turbo/
.pnpm-store/
*.tsbuildinfo

# apogee runtime data
/data/
*.duckdb
*.duckdb.wal
*.duckdb.tmp

# Local env
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json.example
*.swp

# Logs
*.log

# Claude Code local state
.claude/data/
.claude/logs/
# Developer-only guidance for Claude Code sessions on this repo. The
# file documents internal PR conventions, dev commands, and
# architecture orientation, all of which duplicate information that
# already lives in README / CONTRIBUTING / docs/ for OSS visitors.
# Kept local-only so the public repo stays focused on user-facing
# material. Contributors who run Claude Code against this repo can
# maintain their own CLAUDE.md — it is no longer a shared artefact.
CLAUDE.md
